#!name=通用签到(NewAPI)
#!desc=适配所有 NewAPI 中转站，自动抓取 /api/user/self 请求头、定时签到、查看账号状态
#!author=lihyee
#!homepage=https://github.com/lihyee/NoAds
#!icon=https://raw.githubusercontent.com/Toperlock/Quantumult/main/icon/clock.png

[Script]
http-request ^https:\/\/.*\/api\/user\/self$ script-path=https://raw.githubusercontent.com/lihyee/NoAds/main/NewAPI_Loon.js, requires-body=false, timeout=60, tag=NewAPI参数获取
cron "10 9 * * *" script-path=https://raw.githubusercontent.com/lihyee/NoAds/main/NewAPI_Loon.js, timeout=60, tag=通用签到(NewAPI)
cron "20 9 * * *" script-path=https://raw.githubusercontent.com/lihyee/NoAds/main/NewAPI_Status_Loon.js, timeout=60, tag=查看NewAPI状态

[MITM]
hostname = *
