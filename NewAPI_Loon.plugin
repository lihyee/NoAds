#!name=通用签到(NewAPI)
#!desc=适配所有 NewAPI 源码搭建中转站，先抓 /api/user/self 保存请求头，再定时自动签到
#!author=YourName
#!homepage=https://github.com/你的仓库
#!icon=https://raw.githubusercontent.com/Toperlock/Quantumult/main/icon/clock.png

[Script]
http-request ^https:\/\/.*\/api\/user\/self$ script-path=https://raw.githubusercontent.com/你的仓库/你的仓库名/main/NewAPI_Loon.js, requires-body=false, timeout=60, tag=NewAPI参数获取
cron "10 9 * * *" script-path=https://raw.githubusercontent.com/你的仓库/你的仓库名/main/NewAPI_Loon.js, timeout=60, tag=通用签到(NewAPI)

[MITM]
hostname = *
